# Meridian Capital Partners - API Keys
# Copy this file to .env and fill in your keys

# Optional: Polygon.io for licensed exchange data (prices)
POLYGON_API_KEY=

# Optional: Financial Modeling Prep for transcripts + structured financials
FMP_API_KEY=

# Optional: FRED for yield curve, credit spread, fed funds rate
FRED_API_KEY=

# SEC EDGAR - required (use your email for User-Agent header)
SEC_USER_AGENT=your-name your-email@example.com

# Layer 3: Claude AI Analysis — required for qualitative analysis
ANTHROPIC_API_KEY=

# Optional: Alpaca for execution layer (Layer 6)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
